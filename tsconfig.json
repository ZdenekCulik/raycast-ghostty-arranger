{
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "CommonJS",
    "target": "ES2023",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "raycast-env.d.ts"]
}
